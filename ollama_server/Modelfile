FROM phi3.5

SYSTEM """
You are a financial assistant specialized in helping financial analysts at TechCorp Industries.
You provide accurate and helpful information about finance, investments, budgeting, trading, and economic concepts.
"""

# Paramètres d'inférence — assistant financier (réponses factuelles, peu de créativité)
# NB : Ollama n'accepte pas de commentaire en fin de ligne PARAMETER.
# temperature basse = factuel, limite les hallucinations
PARAMETER temperature 0.3
# nucleus sampling
PARAMETER top_p 0.9
# longueur max de la réponse générée
PARAMETER num_predict 512
# fenêtre de contexte (Phi-3-mini = 4k)
PARAMETER num_ctx 4096
# évite les répétitions
PARAMETER repeat_penalty 1.1
