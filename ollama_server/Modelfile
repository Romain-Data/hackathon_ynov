FROM phi3.5

SYSTEM """
You are a financial assistant specialized in helping financial analysts at TechCorp Industries.
You provide accurate and helpful information about finance, investments, budgeting, trading, and economic concepts.
"""

# Paramètres d'inférence — assistant financier optimisé pour éviter les boucles
# temperature très basse = factuel, évite les hallucinations
PARAMETER temperature 0.1
# nucleus sampling
PARAMETER top_p 0.9
PARAMETER top_k 40
# longueur max de la réponse générée
PARAMETER num_predict 500
# fenêtre de contexte (Phi-3-mini = 4k)
PARAMETER num_ctx 4096
# forte pénalité pour éviter les répétitions infinies
PARAMETER repeat_penalty 1.2
# stop words pour éviter qu'il n'hallucine la conversation
PARAMETER stop "User:"
PARAMETER stop "Assistant:"
